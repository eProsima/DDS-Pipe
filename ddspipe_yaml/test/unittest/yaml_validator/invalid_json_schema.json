{
    "$schema":"http://json-schema.org/draft-07/schema#",
    "$ref":"#/definitions/BaseObject",
    "definitions":{
        "BaseObject":{
            "type":"object",
            "additionalProperties":false,
            "properties":{
                "threads":{
                    "type":"integer"
                },
                "version":{
                    "type":"string",
                    "enum":[
                        "v3.0"
                    ]
                },
                "allowlist":{
                    "type":"array",
                    "items":{
                        "$ref":"#/definitions/TopicFilter"
                    }
                },
                "blocklist":{
                    "type":"array",
                    "items":{
                        "$ref":"#/definitions/TopicFilter"
                    }
                },
                "builtin-topics":{
                    "type":"array",
                    "items":{
                        "$ref":"#/definitions/TopicBuiltins"
                    }
                },
                "participants":{
                    "type":"array",
                    "minItems":1,
                    "items":{
                        "$ref":"#/definitions/Participant"
                    },
                    "uniqueKeys":[
                        "/name"
                    ]
                }
            },
            "required":[
                "version",
                "participants"
            ],
            "title":"BaseObject"
        }
}